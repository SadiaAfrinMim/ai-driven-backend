generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USER ====================
enum UserRole {
  USER
  ADMIN
  MANAGER
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password      String
  role          UserRole  @default(USER)
  profileImage  String?
  bio           String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relationships
  items         Item[]
  reviews       Review[]
  blogs         Blog[]
  chatHistory   ChatHistory[]
  notifications Notification[]
}

// ==================== ITEM ====================
enum ItemStatus {
  PENDING
  APPROVED
  REJECTED
}

model Item {
  id          String      @id @default(uuid())
  title       String
  description String      @db.Text
  price       Float
  quantity    Int         @default(0)
  location    String
  rating      Float       @default(0)
  category    String
  tags        String[]
  images      String[]
  isAIContent Boolean     @default(false)

  status      ItemStatus  @default(PENDING)

  ownerId     String
  owner       User        @relation(fields: [ownerId], references: [id])
  reviews     Review[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// ==================== REVIEW ====================
model Review {
  id        String   @id @default(uuid())
  comment   String   @db.Text
  rating    Int      @default(5)

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  itemId    String
  item      Item     @relation(fields: [itemId], references: [id])

  createdAt DateTime @default(now())
}

// ==================== BLOG ====================
model Blog {
  id            String   @id @default(uuid())
  title         String
  content       String   @db.Text
  thumbnail     String?
  isAIGenerated Boolean  @default(true)

  authorId      String
  author        User     @relation(fields: [authorId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ==================== CHAT HISTORY ====================
model ChatHistory {
  id        String   @id @default(uuid())
  message   String   @db.Text // User input
  response  String   @db.Text // AI response

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// ==================== AI INSIGHT ====================
model AIInsight {
  id        String   @id @default(uuid())
  topic     String   // e.g., "Monthly Sales Analysis"
  insight   String   @db.Text // AI generated summary
  chartData Json?    // JSON format data for frontend charts

  createdAt DateTime @default(now())
}

// ==================== NOTIFICATION ====================
model Notification {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  title       String
  message     String
  type        NotificationType
  isRead      Boolean  @default(false)
  relatedId   String?  // Optional ID of related entity (item, review, etc.)
  relatedType String?  // Type of related entity (ITEM, REVIEW, etc.)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}
