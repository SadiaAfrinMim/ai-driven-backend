model Blog {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  thumbnail String?
  isAIGenerated Boolean @default(true)
  
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}