model Review {
  id        String   @id @default(uuid())
  comment   String   @db.Text
  rating    Int      @default(5)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id])

  createdAt DateTime @default(now())
}