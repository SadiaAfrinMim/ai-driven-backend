# ============================
# ROOT .gitignore - AI Product Suggestion
# ============================

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build outputs (CRITICAL for backend)
dist/
build/
.next/
out/

# Environment files (NEVER commit secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# OS generated files
.DS_Store
Thumbs.db

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo
*~

# Testing
coverage/
.nyc_output/
jest-coverage/

# Prisma
prisma/migrations/*
!prisma/migrations/migration_lock.toml

# Misc
*.tsbuildinfo
.cache/
tmp/
temp/

# Backend specific
backend/dist/
backend/logs/
backend/*.log

# Frontend specific (also covered by frontend/.gitignore but for safety)
frontend/.next/
frontend/out/
frontend/node_modules/

# Docker / deployment
docker-compose.override.yml
.env 
.env 
.env 
.env 
