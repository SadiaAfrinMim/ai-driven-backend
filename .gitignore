# Backend-specific .gitignore
# This is in addition to the root .gitignore

# Compiled output
dist/
build/

# Dependencies
node_modules/

# Environment & secrets
.env
.env.local
.env.*.local
*.env
config/secrets.*

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Prisma generated files (keep schema & migrations, ignore generated client if needed)
# generated/

# OS / Editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Testing
coverage/
.nyc_output/

# Misc
*.tsbuildinfo
.cache/
tmp/
temp/
