enum UserRole {
  USER
  ADMIN
  MANAGER
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password      String
  role          UserRole  @default(USER)
  profileImage  String?
  bio           String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relationships
  items         Item[]
  reviews       Review[]
  blogs         Blog[]
  chatHistory   ChatHistory[]
}


model Item {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  price       Float
  location    String
  rating      Float    @default(0)
  category    String
  tags        String[] // AI Auto-tagging output
  images      String[] // Multiple images support
  isAIContent Boolean  @default(false) // AI দিয়ে জেনারেট করা কি না

  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  reviews     Review[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


model Review {
  id        String   @id @default(uuid())
  comment   String   @db.Text
  rating    Int      @default(5)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id])

  createdAt DateTime @default(now())
}


model Blog {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  thumbnail String?
  isAIGenerated Boolean @default(true)
  
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model ChatHistory {
  id        String   @id @default(uuid())
  message   String   @db.Text // User input
  response  String   @db.Text // AI response
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}


model AIInsight {
  id        String   @id @default(uuid())
  topic     String   // e.g., "Monthly Sales Analysis"
  insight   String   @db.Text // AI generated summary
  chartData Json?    // JSON format data for frontend charts

  createdAt DateTime @default(now())
}


১. Auth Module (ভিত্তি - সবার আগে এটি করুন)
এটি আপনার অ্যাপের গেটওয়ে। লগইন এবং রেজিস্ট্রেশন ছাড়া আপনি ড্যাশবোর্ড বা ডাইনামিক কোনো ফিচার টেস্ট করতে পারবেন না।

কাজ: Registration, Login, Social Login (Google), Demo Login (auto-fill)।

কেন দরকার: রিকোয়ারমেন্ট অনুযায়ী User, Admin, এবং Manager রোল হ্যান্ডেল করার জন্য।

২. User Module
লগইন করার পর ইউজারের ব্যক্তিগত তথ্যের জন্য এটি প্রয়োজন।

কাজ: Profile Page (Editable), Role Management, User Overview।

কেন দরকার: রিকোয়ারমেন্টে থাকা "Profile page with editable info" এবং "Dashboard sidebar" এর জন্য।

৩. Item Module (কোর মডিউল)
এটি আপনার অ্যাপের প্রধান অংশ যেখানে সব পণ্য বা সেবা লিস্ট করা থাকবে।

কাজ: Create Item, Update, Delete, Search, Filter, Sort, Pagination।

কেন দরকার: হোমপেজের "Core Listing", "Details Page", এবং "Explore Page" এর জন্য।

৪. AI Module (স্মার্ট ফিচারস)
আপনার প্রজেক্টের সবচেয়ে আকর্ষণীয় অংশ এটি।

কাজ: AI Content Generator (Description লেখা), AI Auto Tagging (ট্যাগ জেনারেট করা), অথবা AI Chat Assistant।

কেন দরকার: রিকোয়ারমেন্ট অনুযায়ী কমপক্ষে ২টি AI ফিচার ইমপ্লিমেন্ট করার জন্য।

৫. Review/Feedback Module
ইউজার এনগেজমেন্ট এবং ডেটা এনালাইসিস ফিচারের জন্য এটি জরুরি।

কাজ: Rating দেওয়া, Comment করা, এবং রিভিউ লিস্ট দেখানো।

কেন দরকার: Details পেজে রিভিউ দেখানো এবং "AI Data Analyzer" দিয়ে এই রিভিউগুলো এনালাইসিস করার জন্য।



প্রজেক্টের পুরো স্ট্রাকচার এবং লজিক্যাল ফ্লো একনজরে দেখার জন্য একটি Complete Overview ফাইল নিচে দেওয়া হলো। এটি আপনি আপনার প্রজেক্টের রুট ডিরেক্টরিতে OVERVIEW.md বা STRUCTURE.md নামে সেভ করে রাখতে পারেন। এটি আপনাকে এবং আপনার কোড রিভিউয়ারকে প্রজেক্টের আর্কিটেকচার বুঝতে সাহায্য করবে।

🚀 AI-Powered Full Stack Project Overview
🏗️ Backend Architecture: Modular Pattern
ব্যাকএন্ডটি Modular Pattern অনুসরণ করে তৈরি করা হয়েছে, যেখানে প্রতিটি ফিচার (Module) স্বাধীন এবং স্বয়ংসম্পূর্ণ।

